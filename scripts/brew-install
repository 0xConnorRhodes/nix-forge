#!/usr/bin/env bash

set -euo pipefail

if ! command -v brew &>/dev/null; then
  echo "Homebrew is not installed."
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BREWFILE="$SCRIPT_DIR/../hosts/traveller/Brewfile"

if [ ! -f "$BREWFILE" ]; then
  echo "Brewfile not found at $BREWFILE"
  exit 1
fi

brew bundle --file "$BREWFILE"
